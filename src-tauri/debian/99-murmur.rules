# Grant the active local user read access to keyboard input devices so
# Murmur can detect its global push-to-talk hotkey on Wayland sessions
# (where the X11 XGrabKey path used by the standard global-shortcut
# plugin cannot see hardware key events for non-focused windows).
#
# `TAG+="uaccess"` causes systemd-logind to ACL these devices to the
# active session user at login, with no group membership required and
# no log out / log in dance. See systemd.device(5) for details.
#
# Murmur opens these devices read-only. Input is never injected through
# /dev/input or uinput; text injection uses wtype / xdotool / clipboard
# fallback at user privilege.
KERNEL=="event*", SUBSYSTEM=="input", TAG+="uaccess"

# Grant the privileged input helper write access to /dev/uinput so it
# can synthesise key events for paste-on-transcribe. The helper is the
# only Murmur binary with this capability (via setgid `input`); the main
# murmur binary stays unprivileged.
KERNEL=="uinput", SUBSYSTEM=="misc", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"
