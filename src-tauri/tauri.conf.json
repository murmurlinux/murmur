{
  "productName": "Murmur",
  "version": "0.1.1",
  "identifier": "com.murmurlinux.murmur",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Murmur",
        "width": 690,
        "height": 376,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true
      },
      {
        "label": "popup",
        "title": "Murmur Recording",
        "url": "popup.html",
        "width": 180,
        "height": 44,
        "minWidth": 1,
        "minHeight": 1,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "targets": ["deb", "appimage"],
    "shortDescription": "AI voice-to-text gadget for Linux",
    "longDescription": "Murmur is a Linux-native voice-to-text desktop gadget. Hold a button or hotkey, speak, and text appears at your cursor in any application. Powered by whisper.cpp for fast local transcription.",
    "homepage": "https://murmurlinux.com",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1", "xdotool"]
      }
    }
  }
}
